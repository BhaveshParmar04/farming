        }),
        ("Eligibility & Benefits", {
            "fields": ("eligibility", "benefits", "required_documents")
        }),
        ("Official Links", {
            "fields": ("official_details_url", "apply_url")
        }),
        ("Metadata", {
            "fields": ("created_at",)
        }),
        ("Extra Info", {
            "fields": ("keywords",)
        }),
    )

@admin.register(CropActivity, site=farming_admin_site)
class CropActivityAdmin(admin.ModelAdmin):
